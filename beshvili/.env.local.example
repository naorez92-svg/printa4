# ═══════════════════════════════════════════════
#  בשבילי — Environment Variables
#  Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════════

# ── Frontend (Vite needs VITE_ prefix) ──────────
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase CLI (used only by setup.sh) ─────────
# Project Ref = "xxxxxxxxxxxx" from your URL above
SUPABASE_PROJECT_REF=xxxxxxxxxxxx

# Personal Access Token: supabase.com → Account (top-right) → Access Tokens → Generate new
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server-side secret (NEVER use VITE_ prefix!) ─
# Sent ONLY to Supabase Edge Function via setup.sh → supabase secrets set
ANTHROPIC_API_KEY=sk-ant-api03-...
