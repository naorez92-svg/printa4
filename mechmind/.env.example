# MechMind — משתני סביבה
# העתק לקובץ .env ומלא ערכים. לעולם אל תעלה .env ל-git.

# מפתח Anthropic API (חובה לפיצ'רים מבוססי AI: צ'אט, קורא שרטוטים, CAD מתיאור חופשי)
ANTHROPIC_API_KEY=

# מודל ברירת מחדל (אפשר להחליף)
MECHMIND_MODEL=claude-sonnet-5

# כתובת מסד הנתונים (ברירת מחדל: SQLite מקומי)
DATABASE_URL=sqlite:///./mechmind.db

# תיקיית קבצי תוצרים (STEP/DXF/PDF/XLSX)
ARTIFACTS_DIR=./artifacts

# מקורות מורשים ל-CORS (מופרדים בפסיק)
CORS_ORIGINS=http://localhost:5173

# הגבלת קצב לבקשות יקרות (שניות בין בקשות לכל לקוח)
RATE_LIMIT_SECONDS=15
